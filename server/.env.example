# DesignGuardian AI Server Environment

PORT=3000

# Gemini & OpenAI APIs configuration
GEMINI_API_KEY=
OPENAI_API_KEY=

# Microsoft Foundry IQ Knowledge Layer integration
# If unconfigured, the server automatically defaults to the LocalKnowledgeProvider (offline mode)
FOUNDRY_ENDPOINT=https://your-foundry-endpoint.microsoft.com
FOUNDRY_PROJECT_ID=your-project-id
FOUNDRY_AGENT_ID=your-agent-id
FOUNDRY_API_KEY=your-api-key
